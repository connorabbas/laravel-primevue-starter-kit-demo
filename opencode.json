{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "primevue": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "-p",
                "@modelcontextprotocol/sdk@1.25.2",
                "-p",
                "@primevue/mcp@4.5.4",
                "primevue-mcp"
            ]
        }
    }
}